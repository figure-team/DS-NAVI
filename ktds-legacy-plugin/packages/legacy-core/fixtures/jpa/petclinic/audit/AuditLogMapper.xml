<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petclinic.audit.AuditLogMapper">
  <select id="selectAuditLogsByOwner" resultType="java.lang.String">
    SELECT message FROM audit_log WHERE owner_id = #{ownerId}
  </select>
</mapper>
